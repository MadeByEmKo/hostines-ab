---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getUrl } from '../utils/paths.js';

const photos = [
  { src: getUrl('/images/interior.png'), alt: 'Interiér restaurace' },
  { src: getUrl('/images/zahrada.png'),  alt: 'Letní zahrádka' },
  { src: getUrl('/images/svickova.png'), alt: 'Svíčková na smetaně' },
  { src: getUrl('/images/grill.png'),    alt: 'Grilovaná žebra' },
  { src: getUrl('/images/rizek.png'),    alt: 'Smažený řízek' },
  { src: getUrl('/images/polevka.png'),  alt: 'Hovězí vývar' },
  { src: getUrl('/images/pivo.png'),     alt: 'Čepované pivo' },
  { src: getUrl('/images/hero.png'),     alt: 'Exteriér hostince' },
];
---

<BaseLayout title="Fotogalerie" description="Fotogalerie Hostince AB – interiér, letní zahrádka, jídla a pivo. Nahlédněte do naší restaurace v Městečku u Nespek.">
  <Header />

  <div class="page-hero">
    <div class="container">
      <span class="badge">Galerie</span>
      <h1 class="mt-md">Fotogalerie</h1>
      <p class="lead mt-md">Nahlédněte do světa Hostince AB</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <!-- Filter tabs -->
      <div class="gallery-filters reveal" role="group" aria-label="Filtr galerie">
        <button class="gal-filter active" data-cat="all"     id="gal-filter-all">Vše</button>
        <button class="gal-filter"        data-cat="interier" id="gal-filter-interier">Interiér</button>
        <button class="gal-filter"        data-cat="jidlo"   id="gal-filter-jidlo">Jídlo</button>
        <button class="gal-filter"        data-cat="zahrada" id="gal-filter-zahrada">Zahrada</button>
      </div>

      <div class="gallery-grid reveal" id="gallery-grid">
        {photos.map((photo, i) => (
          <div
            class="gallery-item"
            data-cat={photo.alt.toLowerCase().includes('jídl') || photo.alt.toLowerCase().includes('vývar') || photo.alt.toLowerCase().includes('řízek') || photo.alt.toLowerCase().includes('svíčk') || photo.alt.toLowerCase().includes('žebra') || photo.alt.toLowerCase().includes('pivo') ? 'jidlo' : photo.alt.toLowerCase().includes('zahrad') ? 'zahrada' : 'interier'}
            onclick={`openLightbox(${i})`}
            role="button"
            tabindex="0"
            aria-label={`Zobrazit: ${photo.alt}`}
            id={`gallery-item-${i}`}
          >
            <img src={photo.src} alt={photo.alt} loading="lazy" />
            <div class="gallery-caption">{photo.alt}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Prohlížeč fotografií">
    <button class="lb-close" id="lb-close" aria-label="Zavřít">✕</button>
    <button class="lb-prev"  id="lb-prev"  aria-label="Předchozí">‹</button>
    <button class="lb-next"  id="lb-next"  aria-label="Následující">›</button>
    <div class="lb-img-wrap">
      <img id="lb-img" src="" alt="" />
      <div class="lb-caption" id="lb-caption"></div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .gallery-filters {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
  }
  .gal-filter {
    padding: 0.5rem 1.25rem;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.87rem;
    font-weight: 500;
    color: var(--clr-text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .gal-filter:hover { border-color: var(--clr-gold); color: var(--clr-cream); }
  .gal-filter.active { background: var(--clr-gold); border-color: var(--clr-gold); color: var(--clr-bg); }

  .gallery-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 0.75rem;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
    opacity: 0;
    transition: opacity var(--transition);
    z-index: 2;
  }
  .gallery-item:hover .gallery-caption { opacity: 1; }
  .gallery-item { cursor: zoom-in; }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .lightbox.open { display: flex; }
  .lb-img-wrap {
    max-width: 90vw;
    max-height: 90vh;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  #lb-img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }
  .lb-caption {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    margin-top: var(--space-md);
    text-align: center;
  }
  .lb-close, .lb-prev, .lb-next {
    position: absolute;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.4rem;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    backdrop-filter: blur(8px);
  }
  .lb-close { top: 1.5rem; right: 1.5rem; width: 44px; height: 44px; }
  .lb-prev  { left: 1rem; top: 50%; transform: translateY(-50%); width: 48px; height: 48px; font-size: 1.8rem; }
  .lb-next  { right: 1rem; top: 50%; transform: translateY(-50%); width: 48px; height: 48px; font-size: 1.8rem; }
  .lb-close:hover, .lb-prev:hover, .lb-next:hover { background: rgba(201,168,76,0.3); }

  .gallery-item[data-hidden] { display: none; }
</style>

<script>
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const getUrl = (path) => path === '/' ? (base || '/') : `${base}${path}`;
  const photos = [
    { src: getUrl('/images/interior.png'), alt: 'Interiér restaurace' },
    { src: getUrl('/images/zahrada.png'),  alt: 'Letní zahrádka' },
    { src: getUrl('/images/svickova.png'), alt: 'Svíčková na smetaně' },
    { src: getUrl('/images/grill.png'),    alt: 'Grilovaná žebra' },
    { src: getUrl('/images/rizek.png'),    alt: 'Smažený řízek' },
    { src: getUrl('/images/polevka.png'),  alt: 'Hovězí vývar' },
    { src: getUrl('/images/pivo.png'),     alt: 'Čepované pivo' },
    { src: getUrl('/images/hero.png'),     alt: 'Exteriér hostince' },
  ];

  let current = 0;
  const lightbox = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
  const lbCap    = document.getElementById('lb-caption')!;

  (window as any).openLightbox = (i: number) => {
    current = i;
    lbImg.src = photos[i].src;
    lbImg.alt = photos[i].alt;
    lbCap.textContent = photos[i].alt;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  const closeLB = () => {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  };

  const showNext = () => { current = (current + 1) % photos.length; (window as any).openLightbox(current); };
  const showPrev = () => { current = (current - 1 + photos.length) % photos.length; (window as any).openLightbox(current); };

  document.getElementById('lb-close')?.addEventListener('click', closeLB);
  document.getElementById('lb-next')?.addEventListener('click', showNext);
  document.getElementById('lb-prev')?.addEventListener('click', showPrev);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLB(); });
  document.addEventListener('keydown', e => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key === 'Escape') closeLB();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'ArrowLeft')  showPrev();
  });

  // Gallery filter
  document.querySelectorAll('.gal-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gal-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat;
      document.querySelectorAll('.gallery-item').forEach(item => {
        const el = item as HTMLElement;
        if (cat === 'all' || el.dataset.cat === cat) {
          el.removeAttribute('data-hidden');
          el.style.display = '';
        } else {
          el.setAttribute('data-hidden', '');
          el.style.display = 'none';
        }
      });
    });
  });
</script>
