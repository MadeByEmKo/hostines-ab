---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// Daily menu – read from content file
import { readFileSync } from 'fs';
import { join } from 'path';

let dailyMenu = { date: '', soups: [], mains: [] };
try {
  const raw = readFileSync(join(process.cwd(), 'content/daily-menu.md'), 'utf8');
  // Simple frontmatter parser
  const fm = raw.match(/^---\n([\s\S]*?)\n---/);
  if (fm) {
    const lines = fm[1].split('\n');
    lines.forEach(l => {
      if (l.startsWith('date:'))   dailyMenu.date  = l.replace('date:', '').trim();
    });
    // Extract soups and mains arrays
    const soupsMatch  = raw.match(/soups:([\s\S]*?)(?=mains:|$)/);
    const mainsMatch  = raw.match(/mains:([\s\S]*?)(?=---|$)/);
    const parseItems = (block) => block ? block.split('\n').filter(l => l.trim().startsWith('-')).map(l => {
      const [name, price] = l.replace(/^\s*-\s*/, '').split('|').map(s => s.trim());
      return { name, price: price || '' };
    }) : [];
    dailyMenu.soups = parseItems(soupsMatch?.[1]);
    dailyMenu.mains = parseItems(mainsMatch?.[1]);
  }
} catch(e) { /* fallback – show placeholder */ }
---

<BaseLayout title="Jídelní lístek" description="Denní menu od 99 Kč a stálý jídelní lístek Hostince AB v Městečku. Polévky, hlavní jídla, dezerty, nápoje.">
  <Header />

  <div class="page-hero">
    <div class="container">
      <span class="badge">Kuchyně</span>
      <h1 class="mt-md">Jídelní & nápojový lístek</h1>
      <p class="lead mt-md">Poctivá česká kuchyně z čerstvých surovin · Denní menu 11–14 hod</p>
    </div>
  </div>

  <section class="section" id="denni">
    <div class="container">
      <div class="menu-tabs reveal">
        <button class="tab-btn active" id="tab-denni"   data-tab="denni">🍽️ Denní menu</button>
        <button class="tab-btn"        id="tab-jidelni" data-tab="jidelni">📜 Jídelní lístek</button>
        <button class="tab-btn"        id="tab-napoje"  data-tab="napoje">🍺 Nápojový lístek</button>
      </div>

      <!-- DENNÍ MENU -->
      <div class="tab-content" id="content-denni">
        <div class="daily-header reveal">
          <div>
            <h2>Denní menu</h2>
            <p class="lead">Platné {dailyMenu.date || 'dnes'} · Vydáváme 11:00 – 14:00</p>
          </div>
          <div class="daily-badge-wrap">
            <span class="daily-price-badge">od 99 Kč</span>
            <a href="/menu?print=1" class="btn btn-ghost btn-sm no-print" id="menu-print-btn" onclick="window.print(); return false;">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Vytisknout
            </a>
          </div>
        </div>

        {dailyMenu.soups.length > 0 ? (
          <div class="menu-card reveal">
            <div class="menu-category">
              <div class="menu-category-title">🥣 Polévky</div>
              {dailyMenu.soups.map(item => (
                <div class="menu-item">
                  <div><div class="menu-item-name">{item.name}</div></div>
                  <div class="menu-item-price">{item.price}</div>
                </div>
              ))}
            </div>
            <div class="menu-category">
              <div class="menu-category-title">🍽️ Hlavní jídla</div>
              {dailyMenu.mains.map(item => (
                <div class="menu-item">
                  <div><div class="menu-item-name">{item.name}</div></div>
                  <div class="menu-item-price">{item.price}</div>
                </div>
              ))}
            </div>
          </div>
        ) : (
          <div class="daily-placeholder reveal">
            <div class="placeholder-icon">🍴</div>
            <h3>Dnešní menu bude brzy zveřejněno</h3>
            <p>Aktuální nabídku zjistíte také telefonicky nebo na Facebooku.</p>
            <div class="flex gap-md flex-wrap items-center mt-lg" style="justify-content:center">
              <a href="tel:+420737484116" class="btn btn-primary" id="menu-phone-btn">+420 737 484 116</a>
              <a href="https://www.facebook.com/Hostinec-Anton%C3%ADn-Bart%C3%A1k-822946991392710" target="_blank" rel="noopener" class="btn btn-outline" id="menu-fb-btn">Facebook</a>
            </div>
          </div>
        )}
      </div>

      <!-- JÍDELNÍ LÍSTEK -->
      <div class="tab-content hidden" id="content-jidelni">
        <div class="menu-print-bar no-print reveal">
          <p class="lead">Stálý jídelní lístek · Ceny včetně DPH</p>
          <button class="btn btn-ghost btn-sm" id="jidelni-print-btn" onclick="window.print()">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Vytisknout lístek
          </button>
        </div>

        <div class="menu-card reveal">
          {[
            { title: '🥣 Polévky', items: [
              { name: 'Hovězí vývar s nudlemi',       desc: 'Domácí vývar, čerstvé nudle',       price: '45 Kč'  },
              { name: 'Gulášová polévka',              desc: 'Hovězí maso, paprika, brambory',    price: '55 Kč'  },
              { name: 'Česnečka se sýrem',             desc: 'Česnek, sýr, krutony',               price: '50 Kč'  },
            ]},
            { title: '🥩 Studené předkrmy', items: [
              { name: 'Utopenec',                      desc: 'Pikantní naložený párek',            price: '65 Kč'  },
              { name: 'Nakládaný hermelín',             desc: 'Hermelín, paprika, česnek, olej',   price: '89 Kč'  },
            ]},
            { title: '🍽️ Hlavní jídla', items: [
              { name: 'Svíčková na smetaně',           desc: 'Hovězí pečeně, smetanová omáčka, houskový knedlík', price: '179 Kč' },
              { name: 'Smažený vepřový řízek',         desc: 'Bramborový salát nebo hranolky',    price: '159 Kč' },
              { name: 'Guláš s knedlíkem',             desc: 'Vepřový guláš, houskový knedlík',  price: '149 Kč' },
              { name: 'Smažený sýr',                   desc: 'Eidam, tatarská omáčka, hranolky', price: '139 Kč' },
              { name: 'Grilovaná žebra',               desc: 'Vepřová žebra, grilovaná zelenina, brambory', price: '229 Kč' },
              { name: 'Kuřecí steak na másle',         desc: 'Kuřecí prsa, americké brambory',   price: '169 Kč' },
            ]},
            { title: '🌱 Bezmasá jídla', items: [
              { name: 'Smažený sýr (bezmasý)',         desc: 'Eidam, hranolky, tatarská omáčka', price: '139 Kč' },
              { name: 'Těstoviny se zeleninou',        desc: 'Sezónní zelenina, parmazán',        price: '129 Kč' },
            ]},
            { title: '🍰 Dezerty', items: [
              { name: 'Palačinky s džemem',            desc: 'S jahodovým nebo meruňkovým džemem', price: '69 Kč' },
              { name: 'Zmrzlinový pohár',              desc: 'Tři kopečky zmrzliny, šlehačka',   price: '59 Kč'  },
            ]},
          ].map(cat => (
            <div class="menu-category">
              <div class="menu-category-title">{cat.title}</div>
              {cat.items.map(item => (
                <div class="menu-item">
                  <div>
                    <div class="menu-item-name">{item.name}</div>
                    <div class="menu-item-desc">{item.desc}</div>
                  </div>
                  <div class="menu-item-price">{item.price}</div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>

      <!-- NÁPOJOVÝ LÍSTEK -->
      <div class="tab-content hidden" id="content-napoje" role="tabpanel">
        <div class="menu-card reveal">
          {[
            { title: '🍺 Čepované pivo', items: [
              { name: 'Gambrinus 11° světlé výčepní', desc: '0,5 l',  price: '45 Kč' },
              { name: 'Pilsner Urquell 12° světlý ležák', desc: '0,5 l', price: '52 Kč' },
              { name: 'Kozel černý 10°',              desc: '0,5 l',  price: '48 Kč' },
              { name: 'Birell nealkoholický',          desc: '0,5 l',  price: '40 Kč' },
            ]},
            { title: '🥤 Nealkoholické', items: [
              { name: 'Kofola',                        desc: '0,3 l',  price: '35 Kč' },
              { name: 'Coca-Cola / Fanta / Sprite',    desc: '0,3 l',  price: '38 Kč' },
              { name: 'Džus',                          desc: '0,2 l',  price: '32 Kč' },
              { name: 'Minerální voda',                desc: '0,33 l', price: '28 Kč' },
            ]},
            { title: '☕ Teplé nápoje', items: [
              { name: 'Espresso',                      desc: 'double shot',  price: '42 Kč' },
              { name: 'Cappuccino',                    desc: '0,2 l',        price: '49 Kč' },
              { name: 'Čaj',                           desc: 'výběr druhů',  price: '35 Kč' },
              { name: 'Horká čokoláda',               desc: '0,2 l',        price: '52 Kč' },
            ]},
            { title: '🥃 Lihoviny a víno', items: [
              { name: 'Slivovice',                     desc: '0,04 l', price: '45 Kč' },
              { name: 'Becherovka',                    desc: '0,04 l', price: '42 Kč' },
              { name: 'Víno bílé / červené',           desc: '0,2 l',  price: '55 Kč' },
              { name: 'Prosecco',                      desc: '0,1 l',  price: '65 Kč' },
            ]},
          ].map(cat => (
            <div class="menu-category">
              <div class="menu-category-title">{cat.title}</div>
              {cat.items.map(item => (
                <div class="menu-item">
                  <div>
                    <div class="menu-item-name">{item.name}</div>
                    <div class="menu-item-desc">{item.desc}</div>
                  </div>
                  <div class="menu-item-price">{item.price}</div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .menu-tabs {
    display: flex;
    gap: var(--space-sm);
    border-bottom: 2px solid var(--clr-border);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
  }
  .tab-btn {
    padding: 0.75rem 1.5rem;
    background: none;
    border: none;
    color: var(--clr-text-muted);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.02em;
  }
  .tab-btn:hover { color: var(--clr-cream); }
  .tab-btn.active { color: var(--clr-gold); border-bottom-color: var(--clr-gold); }

  .hidden { display: none !important; }

  .daily-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }
  .daily-badge-wrap { display: flex; align-items: center; gap: var(--space-md); }
  .daily-price-badge {
    background: linear-gradient(135deg, var(--clr-gold), var(--clr-gold-dark));
    color: var(--clr-bg);
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
  }

  .menu-card {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
  }

  .daily-placeholder {
    text-align: center;
    padding: var(--space-3xl);
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
  }
  .placeholder-icon { font-size: 3rem; margin-bottom: var(--space-lg); }

  .menu-print-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  @media (max-width: 600px) {
    .menu-card { padding: var(--space-lg); }
    .daily-header { flex-direction: column; }
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.add('hidden'));
      tab.classList.add('active');
      const target = document.getElementById(`content-${tab.dataset.tab}`);
      target?.classList.remove('hidden');
    });
  });

  // Open napoje tab if URL has #napoje
  if (window.location.hash === '#napoje') {
    document.getElementById('tab-napoje')?.click();
  }
</script>
