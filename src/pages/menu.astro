<style>
  .menu-tabs { display:flex; gap:var(--space-sm); border-bottom:2px solid var(--clr-border); margin-bottom:var(--space-2xl); flex-wrap:wrap; }
  .tab-btn { padding:.75rem 1.5rem; background:none; border:none; color:var(--clr-text-muted); font-family:var(--font-body); font-size:.9rem; font-weight:600; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-2px; transition:color .2s,border-color .2s; }
  .tab-btn:hover { color:var(--clr-cream); }
  .tab-btn.active { color:var(--clr-gold); border-bottom-color:var(--clr-gold); }
  .hidden { display:none!important; }
  .daily-header { display:flex; justify-content:space-between; align-items:flex-start; gap:var(--space-lg); margin-bottom:var(--space-xl); flex-wrap:wrap; }
  .daily-badge-wrap { display:flex; align-items:center; gap:var(--space-sm); flex-wrap:wrap; }
  .daily-price-badge { background:linear-gradient(135deg,var(--clr-gold),var(--clr-gold-dark)); color:var(--clr-bg); font-weight:700; font-size:1.05rem; padding:.4rem 1rem; border-radius:var(--radius-sm); font-family:var(--font-display); }
  .menu-card { background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-lg); padding:var(--space-2xl); }
  .menu-item-clickable { cursor:pointer; border-radius:var(--radius-sm); transition:background .15s; }
  .menu-item-clickable:hover { background:rgba(201,168,76,.06); }
  .menu-item-right { display:flex; align-items:center; gap:var(--space-sm); flex-shrink:0; }
  .order-badge { font-size:1rem; opacity:.5; transition:opacity .2s; text-decoration:none; }
  .menu-item-clickable:hover .order-badge { opacity:1; }
  .menu-note { margin-top:var(--space-xl); padding-top:var(--space-lg); border-top:1px solid var(--clr-border); font-size:.85rem; color:var(--clr-text-muted); text-align:center; line-height:1.8; }
  .menu-print-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-xl); flex-wrap:wrap; gap:var(--space-md); }
  .daily-placeholder { text-align:center; padding:var(--space-3xl); background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-lg); }
  .placeholder-icon { font-size:3rem; margin-bottom:var(--space-lg); }
  @media (max-width:600px) { .menu-card { padding:var(--space-lg); } .daily-header { flex-direction:column; } }
</style>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.add('hidden'));
      tab.classList.add('active');
      document.getElementById(`content-${(tab as HTMLElement).dataset.tab}`)?.classList.remove('hidden');
    });
  });
  if (window.location.hash === '#napoje') document.getElementById('tab-napoje')?.click();
</script>
