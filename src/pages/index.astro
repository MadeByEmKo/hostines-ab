---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getUrl } from '../utils/paths.js';
---

<BaseLayout title="Hostinec AB" description="Tradiční česká kuchyně v Městečku u Nespek. Denní menu od 99 Kč, skupinové akce, rezervace stolů. Čepujeme Prazdroj, Gambrinus a Kozel.">
  <Header />

  <!-- HERO -->
  <section class="hero" aria-label="Úvodní banner">
    <div class="hero-bg">
      <picture>
        <source srcset={`${getUrl('/images/restaurant/Image_in2-mobile.webp')} 480w, ${getUrl('/images/restaurant/Image_in2-tablet.webp')} 768w, ${getUrl('/images/restaurant/Image_in2.webp')} 1920w`} type="image/webp" />
        <img src={getUrl('/images/restaurant/Image_in2.JPG')} alt="Hostinec AB interiér" class="hero-img shimmer-img" fetchpriority="high" onload="this.classList.add('loaded')" />
      </picture>
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content container">
      <div class="hero-badge">
        <span class="badge">Otevřeno dnes 11:00 – 22:00</span>
      </div>
      <h1 class="hero-title">
        <span class="hero-subtitle">Vítá Vás</span>
        <span class="hero-main-title">Hostinec Antonín Barták</span>
      </h1>
      <div class="hero-stats" style="margin-top: 30px;">
        <div class="stat">
          <span class="stat-emoji">📋</span>
          <strong>99 Kč</strong>
          <span>Denní menu</span>
        </div>
        <div class="stat">
          <span class="stat-emoji">🍺</span>
          <strong>4 druhy</strong>
          <span>Piva</span>
        </div>
        <div class="stat">
          <span class="stat-emoji">👥</span>
          <strong>50+ osob</strong>
          <span>Kapacita</span>
        </div>
        <div class="stat">
          <span class="stat-emoji">🕐</span>
          <strong>11:00-22:00</strong>
          <span>Otevřeno</span>
        </div>
      </div>
      <div class="hero-ctas" style="margin-top: 30px;">
        <a href={getUrl('/rezervace')} class="btn btn-primary" id="hero-rezervace-btn">
          Rezervace stolu
        </a>
        <a href={getUrl('/menu')} class="btn btn-outline" id="hero-menu-btn">
          Zobrazit menu
        </a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- QUICK CARDS -->
  <section class="section-sm quick-cards" aria-label="Rychlé akce">
    <div class="container">
      <div class="qc-grid reveal">
        <a href={getUrl('/menu#denni')} class="qc-card" id="qc-denni-menu">
          <div class="qc-icon"><i class="fa-solid fa-utensils"></i></div>
          <div>
            <div class="qc-title">Denní menu</div>
            <div class="qc-sub">Polední menu od 99 Kč · 11–14 hod</div>
          </div>
          <i class="fa-solid fa-arrow-right qc-arrow"></i>
        </a>
        <a href={getUrl('/skupiny')} class="qc-card" id="qc-skupiny">
          <div class="qc-icon"><i class="fa-solid fa-cake-candles"></i></div>
          <div>
            <div class="qc-title">Skupinové akce</div>
            <div class="qc-sub">Oslavy, firemní akce, svatby</div>
          </div>
          <i class="fa-solid fa-arrow-right qc-arrow"></i>
        </a>
        <a href={getUrl('/rezervace')} class="qc-card" id="qc-rezervace">
          <div class="qc-icon"><i class="fa-solid fa-calendar-days"></i></div>
          <div>
            <div class="qc-title">Rezervace</div>
            <div class="qc-sub">Online rezervace stolu 24/7</div>
          </div>
          <i class="fa-solid fa-arrow-right qc-arrow"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- O NÁS ZKRÁTKA -->
  <section class="section about-home" aria-labelledby="about-home-h2">
    <div class="container">
      <div class="about-grid">
        <div class="about-imgs reveal">
          <picture>
            <source srcset={`${getUrl('/images/interior-mobile.webp')} 480w, ${getUrl('/images/interior-tablet.webp')} 768w, ${getUrl('/images/interior.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/interior.png')} alt="Interiér restaurace" class="about-img-main shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
          <picture>
            <source srcset={`${getUrl('/images/zahrada-mobile.webp')} 480w, ${getUrl('/images/zahrada-tablet.webp')} 768w, ${getUrl('/images/zahrada.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/zahrada.png')} alt="Letní zahrádka" class="about-img-sec shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
        </div>
        <div class="about-text reveal">
          <span class="gold-line" aria-hidden="true"></span>
          <span class="badge">Naše příběh</span>
          <h2 id="about-home-h2" class="mt-md">Tradiční hospoda<br /><em>s moderním přístupem</em></h2>
          <p class="mt-md lead">
            Hostinec Antonín Barták je pro Vás znovu otevřen v plném provozu.
            Nabízíme poctivou domácí kuchyni, čerstvé suroviny a srdečné prostředí.
          </p>
          <p class="mt-md">
            Jakmile počasí dovolí, otevíráme venkovní zahrádku s venkovním grilem.
            Čepujeme <strong>Gambrinus 11°, Pilsner Urquell 12°, Kozel černý</strong>
            a nealkoholický <strong>Birell</strong>.
          </p>
          <div class="about-features mt-xl">
            <div class="feature-item">
              <span class="feature-icon"><i class="fa-solid fa-leaf"></i></span>
              <div><strong>Čerstvé suroviny</strong><br /><small>Denně připravované pokrmy</small></div>
            </div>
            <div class="feature-item">
              <span class="feature-icon"><i class="fa-solid fa-beer-mug-empty"></i></span>
              <div><strong>4 druhy piva</strong><br /><small>Čepované i lahvové</small></div>
            </div>
            <div class="feature-item">
              <span class="feature-icon"><i class="fa-solid fa-tree"></i></span>
              <div><strong>Letní zahrádka</strong><br /><small>S venkovním grilem</small></div>
            </div>
          </div>
          <div class="mt-xl flex gap-md flex-wrap">
            <a href={getUrl('/o-nas')} class="btn btn-outline" id="about-home-more-btn">Více o nás</a>
            <a href={getUrl('/menu')} class="btn btn-ghost" id="about-home-menu-btn">Jídelní lístek</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOTO JÍDEL -->
  <section class="section food-section" aria-labelledby="food-h2">
    <div class="container">
      <div class="section-header text-center reveal">
        <span class="gold-line" aria-hidden="true"></span>
        <h2 id="food-h2">Z naší kuchyně</h2>
        <p class="lead">Poctivá česká kuchyně – bezmasá, bezlepková i grilovaná jídla</p>
      </div>
      <div class="food-grid reveal">
        <div class="food-card">
          <picture>
            <source srcset={`${getUrl('/images/svickova-mobile.webp')} 480w, ${getUrl('/images/svickova-tablet.webp')} 768w, ${getUrl('/images/svickova.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/svickova.png')} alt="Svíčková na smetaně" class="shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
          <div class="food-card-body">
            <div class="food-card-name">Svíčková na smetaně</div>
            <div class="food-card-price text-gold">od 179 Kč</div>
          </div>
        </div>
        <div class="food-card food-card-large">
          <picture>
            <source srcset={`${getUrl('/images/grill-mobile.webp')} 480w, ${getUrl('/images/grill-tablet.webp')} 768w, ${getUrl('/images/grill.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/grill.png')} alt="Grilovaná žebírka" class="shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
          <div class="food-card-body">
            <div class="food-card-name">Grilovaná žebírka</div>
            <div class="food-card-price text-gold">od 229 Kč</div>
          </div>
        </div>
        <div class="food-card">
          <picture>
            <source srcset={`${getUrl('/images/rizek-mobile.webp')} 480w, ${getUrl('/images/rizek-tablet.webp')} 768w, ${getUrl('/images/rizek.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/rizek.png')} alt="Smažený řízek" class="shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
          <div class="food-card-body">
            <div class="food-card-name">Smažený řízek</div>
            <div class="food-card-price text-gold">od 159 Kč</div>
          </div>
        </div>
        <div class="food-card">
          <picture>
            <source srcset={`${getUrl('/images/polevka-mobile.webp')} 480w, ${getUrl('/images/polevka-tablet.webp')} 768w, ${getUrl('/images/polevka.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/polevka.png')} alt="Hovězí vývar" class="shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
          <div class="food-card-body">
            <div class="food-card-name">Hovězí vývar</div>
            <div class="food-card-price text-gold">od 45 Kč</div>
          </div>
        </div>
      </div>
      <div class="text-center mt-xl reveal">
        <a href={getUrl('/menu')} class="btn btn-primary" id="food-section-menu-btn">Celý jídelní lístek</a>
      </div>
    </div>
  </section>

  <!-- PIVO SEKCE -->
  <section class="section beer-section" aria-labelledby="beer-h2">
    <div class="container">
      <div class="beer-grid">
        <div class="beer-img reveal">
          <picture>
            <source srcset={`${getUrl('/images/pivo-mobile.webp')} 480w, ${getUrl('/images/pivo-tablet.webp')} 768w, ${getUrl('/images/pivo.webp')} 1920w`} type="image/webp" />
            <img src={getUrl('/images/pivo.png')} alt="Čepované pivo" class="shimmer-img" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
        </div>
        <div class="beer-text reveal">
          <span class="gold-line" aria-hidden="true"></span>
          <h2 id="beer-h2">Čepujeme<br /><em>to nejlepší</em></h2>
          <p class="mt-md lead">Kvalitní české pivo přímo z tanků. Vždy čerstvé, vždy studené.</p>
          <div class="beer-list mt-xl">
            {[
              { name: 'Gambrinus 11°', type: 'světlé výčepní',    deg: '11°' },
              { name: 'Pilsner Urquell', type: 'světlý ležák',    deg: '12°' },
              { name: 'Kozel černý',  type: 'tmavé pivo',         deg: '10°' },
              { name: 'Birell',       type: 'nealkoholické pivo', deg: '0%' },
            ].map(b => (
              <div class="beer-item">
                <div class="beer-deg">{b.deg}</div>
                <div>
                  <div class="beer-name">{b.name}</div>
                  <div class="beer-type">{b.type}</div>
                </div>
              </div>
            ))}
          </div>
          <a href={getUrl('/menu#napoje')} class="btn btn-outline mt-xl" id="beer-napojovy-btn">Nápojový lístek</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner reveal" aria-labelledby="cta-h2">
    <div class="container text-center">
      <h2 id="cta-h2">Plánujete oslavu nebo firemní akci?</h2>
      <p class="lead mt-md">
        Nabízíme prostory pro až 50 hostů, vlastní catering a kompletní organizaci.
      </p>
      <div class="flex gap-md flex-wrap items-center mt-xl" style="justify-content:center">
        <a href={getUrl('/skupiny')} class="btn btn-primary" id="cta-skupiny-btn">Skupinové akce</a>
        <a href={getUrl('/rezervace?typ=akce')} class="btn btn-outline" id="cta-akce-btn">Poptat akci</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    animation: heroZoom 12s ease-out forwards;
  }
  @keyframes heroZoom {
    to { transform: scale(1); }
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 18, 13, 0.88) 0%,
      rgba(15, 28, 20, 0.70) 50%,
      rgba(10, 18, 13, 0.85) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 100px;
    padding-bottom: var(--space-3xl);
    max-width: 700px;
  }
  .hero-badge { margin-bottom: var(--space-lg); }
  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }
  .hero-subtitle {
    font-size: 24px;
    color: #FFFFFF;
    font-weight: 300;
    font-family: var(--font-body);
  }
  .hero-main-title {
    font-size: 56px;
    font-weight: 700;
    font-style: italic;
    color: var(--clr-gold);
    font-family: var(--font-display);
    display: block;
  }
  .hero-sub {
    max-width: 50ch;
    margin-bottom: var(--space-xl);
    color: rgba(232,226,213,0.85);
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .stat-icon { font-size: 1.1rem; color: var(--clr-gold); opacity: 0.7; margin-bottom: 4px; }
  .stat-emoji { font-size: 1.4rem; margin-bottom: 5px; }
  .stat strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--clr-gold);
    line-height: 1;
  }
  .stat span { font-size: 0.78rem; color: var(--clr-text-muted); margin-top: 3px; }
  .stat-divider { width: 1px; height: 40px; background: var(--clr-border); }
  .hero-scroll {
    position: absolute;
    bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .hero-scroll span {
    display: block;
    width: 2px; height: 50px;
    background: linear-gradient(to bottom, var(--clr-gold), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { opacity: 0; transform: scaleY(0); transform-origin: top; }
    50%  { opacity: 1; transform: scaleY(1); }
    100% { opacity: 0; transform: scaleY(1); transform-origin: bottom; }
  }

  /* QUICK CARDS */
  .quick-cards { background: var(--clr-surface); border-bottom: 1px solid var(--clr-border); }
  .qc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .qc-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: var(--clr-bg);
    transition: all var(--transition);
    text-decoration: none;
  }
  .qc-card:hover {
    border-color: var(--clr-gold);
    transform: translateY(-2px);
    box-shadow: var(--shadow-gold);
  }
  .qc-card:hover .qc-icon i,
  .qc-card:hover .qc-arrow {
    color: #E8C547;
  }
  .qc-icon { font-size: 1.8rem; flex-shrink: 0; }
  .qc-title { font-weight: 600; color: var(--clr-cream); margin-bottom: 2px; }
  .qc-sub { font-size: 0.8rem; color: var(--clr-text-muted); }
  .qc-arrow { color: var(--clr-gold); margin-left: auto; flex-shrink: 0; transition: color var(--transition); }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .about-imgs {
    position: relative;
    height: 520px;
  }
  .about-img-main {
    position: absolute;
    top: 0; left: 0;
    width: 80%; height: 80%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .about-img-sec {
    position: absolute;
    bottom: 0; right: 0;
    width: 55%; height: 55%;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 4px solid var(--clr-bg);
    box-shadow: var(--shadow-md);
  }
  .about-features { display: flex; flex-direction: column; gap: var(--space-md); }
  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
  }
  .feature-icon { font-size: 1.4rem; }
  .feature-item strong { color: var(--clr-cream); font-size: 0.95rem; }
  .feature-item small  { color: var(--clr-text-muted); font-size: 0.8rem; }

  /* FOOD */
  .food-section { background: var(--clr-bg-2); }
  .food-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }
  .food-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    transition: all var(--transition);
  }
  .food-card:hover {
    transform: translateY(-4px);
    border-color: rgba(201,168,76,0.4);
    box-shadow: var(--shadow-md);
  }
  .food-card img { width: 100%; height: 200px; object-fit: cover; }
  .food-card-large { grid-row: span 1; }
  .food-card-large img { height: 200px; }
  .food-card-body { padding: var(--space-md); }
  .food-card-name { font-weight: 600; color: var(--clr-cream); }
  .food-card-price { font-size: 0.9rem; margin-top: 4px; font-weight: 600; }

  /* BEER */
  .beer-section {
    background: linear-gradient(135deg, var(--clr-bg) 0%, var(--clr-surface) 100%);
    border-top: 1px solid var(--clr-border);
    border-bottom: 1px solid var(--clr-border);
  }
  .beer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .beer-img img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg), var(--shadow-gold);
  }
  .beer-list { display: flex; flex-direction: column; gap: var(--space-md); }
  .beer-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition);
  }
  .beer-item:hover { border-color: rgba(201,168,76,0.4); }
  .beer-deg {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--clr-gold);
    min-width: 2.5rem;
  }
  .beer-name  { font-weight: 600; color: var(--clr-cream); }
  .beer-type  { font-size: 0.82rem; color: var(--clr-text-muted); }

  /* CTA BANNER */
  .cta-banner {
    padding: var(--space-3xl) 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(44,90,61,0.15));
    border-top: 1px solid var(--clr-border);
    border-bottom: 1px solid var(--clr-border);
  }
  .cta-banner h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
  .cta-banner .lead { margin: 0 auto; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .about-grid, .beer-grid { grid-template-columns: 1fr; gap: var(--space-xl); }
    .about-imgs { height: 320px; }
    .food-grid { grid-template-columns: repeat(2, 1fr); }
    .qc-grid { grid-template-columns: 1fr; }
    .hero-subtitle { font-size: 20px; }
    .hero-main-title { font-size: 44px; }
    .hero-title { gap: 14px; }
  }
  @media (max-width: 600px) {
    .food-grid { grid-template-columns: 1fr; }
    /* 2x2 karta grid pro stats */
    .hero-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
      width: 100%;
    }
    .stat {
      background: rgba(0,0,0,0.35);
      border: 1px solid rgba(212,175,55,0.25);
      border-radius: var(--radius-md);
      padding: var(--space-md);
      align-items: center;
      text-align: center;
    }
    .stat strong { font-size: 1.3rem; }
    .stat-divider { display: none; }
    .hero-ctas { flex-direction: column; width: 100%; }
    .hero-ctas .btn { width: 100%; justify-content: center; }
    .hero-subtitle { font-size: 18px; }
    .hero-main-title { font-size: 36px; }
    .hero-title { gap: 12px; }
  }
</style>
