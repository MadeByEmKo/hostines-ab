---
// MainLayout.astro - Root layout for all pages
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const getUrl = (path) => path === '/' ? (base || '/') : `${base}${path}`;

const {
  title,
  description = 'Hostinec Antonín Barták v Městečku u Nespek. Česká kuchyně, denní menu, skupinové akce, oslavy a rezervace.',
  image = '/images/hero.png',
} = Astro.props;

const siteUrl = 'https://hostinecab.cz';
const fullTitle = title === 'Hostinec AB' ? title : `${title} | Hostinec AB`;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}${base}${image}`} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="cs_CZ" />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={getUrl('/favicon.svg')} />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <title>{fullTitle}</title>

    <!-- Preconnect for fonts (loaded in global CSS) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot name="header-before" />
    <slot />
    <slot name="footer-after" />

    <!-- Mobile Sticky Footer (context-aware) -->
    <div class="mobile-sticky-cta no-print" id="mobile-sticky-footer"
         data-base={base}>
    </div>

    <!-- Scroll reveal + Context-aware CTA -->
    <script>
      // ── Scroll reveal ──────────────────────────────────────────────
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) e.target.classList.add('visible');
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      // ── Context-aware mobile CTA ───────────────────────────────────
      (function () {
        const footer = document.getElementById('mobile-sticky-footer');
        if (!footer) return;
        const base = (footer.dataset.base || '').replace(/\/$/, '');
        const path = window.location.pathname;

        // Strip base prefix for matching
        const rel = base ? path.replace(base, '') : path;

        // Variant definitions: [primaryHref, primaryIcon, primaryLabel, secondaryHref, secondaryIcon, secondaryLabel]
        let v;

        if (/\/objednat/.test(rel)) {
          // D – Objednávka
          v = [
            '#objednat-form', 'fa-solid fa-paper-plane', 'Odeslat objednávku',
            base + '/menu', 'fa-solid fa-arrow-left', 'Zpět na menu'
          ];
        } else if (/\/ubytovani/.test(rel)) {
          // B – Ubytování
          v = [
            base + '/rezervace-pokoje', 'fa-solid fa-bed', 'Rezervovat pobyt',
            base + '/kontakt', 'fa-solid fa-phone', 'Kontakt'
          ];
        } else if (/\/menu/.test(rel)) {
          // C – Menu
          v = [
            base + '/objednat', 'fa-solid fa-bag-shopping', 'Objednat s sebou',
            base + '/rezervace', 'fa-solid fa-calendar-days', 'Rezervace stolu'
          ];
        } else {
          // A – Default (Domů, Skupiny, O nás, Galerie, Kontakt, Rezervace…)
          v = [
            base + '/rezervace', 'fa-solid fa-calendar-days', 'Rezervace stolu',
            base + '/menu', 'fa-solid fa-utensils', 'Zobrazit menu'
          ];
        }

        footer.innerHTML =
          '<a href="' + v[0] + '" class="btn btn-primary btn-sticky">' +
            '<i class="' + v[1] + '"></i><span>' + v[2] + '</span>' +
          '</a>' +
          '<a href="' + v[3] + '" class="btn btn-outline btn-sticky">' +
            '<i class="' + v[4] + '"></i><span>' + v[5] + '</span>' +
          '</a>';

        // Special case: "Odeslat objednávku" should submit the form, not navigate
        if (/\/objednat/.test(rel)) {
          footer.querySelector('a').addEventListener('click', function (e) {
            const form = document.getElementById('takeaway-form');
            if (form) { e.preventDefault(); form.requestSubmit(); }
          });
        }
      })();
    </script>
  </body>
</html>
