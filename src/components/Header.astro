---
// Header.astro - Navigation header
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const getUrl = (path) => path === '/' ? (base || '/') : `${base}${path}`;

const navLinks = [
  { href: getUrl('/'),            label: 'Úvod'          },
  { href: getUrl('/menu'),        label: 'Menu'           },
  { href: getUrl('/ubytovani'),   label: 'Ubytování'      },
  { href: getUrl('/skupiny'),     label: 'Skupinové akce' },
  { href: getUrl('/galerie'),     label: 'Fotogalerie'    },
  { href: getUrl('/o-nas'),       label: 'O nás'          },
  { href: getUrl('/kontakt'),     label: 'Kontakt'        },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="main-header" class="site-header">
  <div class="header-inner container">
    <!-- Logo -->
    <a href={getUrl('/')} class="logo" id="site-logo" aria-label="Hostinec AB - zpět na úvod">
      <img
        src={getUrl('/images/logo.png')}
        alt="Hostinec Antonín Barták – Městečko"
        class="logo-img"
        width="200"
        height="200"
        loading="eager"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="main-nav" aria-label="Hlavní navigace">
      <ul role="list">
        {navLinks.map((link) => {
          const isActive = link.href === (base || '/')
            ? currentPath === (base || '/')
            : currentPath.startsWith(link.href);
          return (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { active: isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- CTA buttons + hamburger -->
    <div class="header-actions">
      <a href={getUrl('/objednat')} class="btn btn-ghost btn-sm no-print" id="header-takeaway-btn">
        🛍️ S sebou
      </a>
      <a href={getUrl('/rezervace')} class="btn btn-primary btn-sm no-print" id="header-rezervace-btn">
        Zamluvit stůl
      </a>
      <button
        class="hamburger no-print"
        id="hamburger-btn"
        aria-label="Otevřít menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobilní navigace" aria-hidden="true">
    <ul role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        </li>
      ))}
      <li class="mobile-ctas">
        <a href={getUrl('/objednat')} class="btn btn-ghost" id="mobile-takeaway-btn">🛍️ Objednat s sebou</a>
        <a href={getUrl('/rezervace')} class="btn btn-primary" id="mobile-rezervace-btn">Zamluvit stůl</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(15, 28, 20, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(201,168,76,0.12);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .site-header.scrolled {
    background: rgba(15, 28, 20, 0.97);
    box-shadow: 0 4px 30px rgba(0,0,0,0.4);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100px;
    gap: 1.5rem;
    transition: height 0.3s ease;
  }
  .site-header.scrolled .header-inner {
    height: 80px;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    padding: 6px 0;
  }
  .logo-img {
    height: 85px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
    transition: transform 0.3s ease, height 0.3s ease, filter 0.3s ease;
  }
  .site-header.scrolled .logo-img {
    height: 68px;
  }
  .logo:hover .logo-img {
    transform: scale(1.05);
    filter: drop-shadow(0 4px 18px rgba(201,168,76,0.4));
  }

  /* Nav */
  .main-nav ul {
    display: flex;
    list-style: none;
    gap: 0.5rem;
  }
  .nav-link {
    display: block;
    padding: 0.45rem 0.8rem;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #9a9080;
    border-radius: 6px;
    transition: color 0.2s;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%; right: 50%;
    height: 1.5px;
    background: #c9a84c;
    transition: left 0.25s ease, right 0.25s ease;
  }
  .nav-link:hover { color: #f5f0e8; }
  .nav-link:hover::after,
  .nav-link.active::after { left: 0.8rem; right: 0.8rem; }
  .nav-link.active { color: #c9a84c; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .btn-sm {
    padding: 0.6rem 1.1rem;
    font-size: 0.8rem;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }
  .hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: #f5f0e8;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    border-top: 1px solid rgba(201,168,76,0.1);
    background: rgba(12, 22, 16, 0.99);
  }
  .mobile-nav.open { display: block; max-height: 520px; padding-bottom: 1rem; }
  .mobile-nav ul { list-style: none; padding: 0.5rem 1.5rem; }
  .mobile-nav li { border-bottom: 1px solid rgba(255,255,255,0.05); }
  .mobile-nav-link {
    display: block;
    padding: 0.9rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #e8e2d5;
    transition: color 0.2s, padding-left 0.2s;
  }
  .mobile-nav-link:hover { color: #c9a84c; padding-left: 0.5rem; }
  .mobile-ctas {
    border-bottom: none !important;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1rem;
    padding-bottom: 0.5rem;
  }
  .mobile-ctas .btn { width: 100%; justify-content: center; }

  @media (max-width: 960px) {
    .main-nav { display: none; }
    .hamburger { display: flex; }
    .header-actions .btn:not(.hamburger) { display: none; }
    .header-inner { height: 80px; }
    .logo-img { height: 64px; }
  }
  @media (max-width: 400px) {
    .logo-img { height: 56px; }
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const updateScroll = () => header?.classList.toggle('scrolled', window.scrollY > 40);
  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  const btn  = document.getElementById('hamburger-btn');
  const mNav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    mNav?.setAttribute('aria-hidden', String(open));
    mNav?.classList.toggle('open', !open);
  });
  mNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      mNav.setAttribute('aria-hidden', 'true');
      mNav.classList.remove('open');
    });
  });
</script>
