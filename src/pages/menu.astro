---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getUrl } from '../utils/paths.js';
import { readFileSync } from 'fs';
import { join } from 'path';

let dm = { date:'', soups:[] as {name:string,price:string}[], bezlepkova:[] as {name:string,price:string}[], bezmasa:[] as {name:string,price:string}[], hotova:[] as {name:string,price:string}[], gril:[] as {name:string,price:string}[], salaty:[] as {name:string,price:string}[], dezerty:[] as {name:string,price:string}[] };
try {
  const raw = readFileSync(join(process.cwd(),'content/daily-menu.md'),'utf8');
  const lines = raw.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');

  let inFm = false, fmLines: string[] = [];
  for (const line of lines) {
    if (line.trim() === '---') { if (!inFm) { inFm = true; continue; } else break; }
    if (inFm) fmLines.push(line);
  }

  const parseSection = (key: string): {name: string; price: string}[] => {
    const result: {name: string; price: string}[] = [];
    let collecting = false;
    for (const line of fmLines) {
      if (line.match(new RegExp('^' + key + '\\s*:'))) { collecting = true; continue; }
      if (collecting) {
        if (line.match(/^\s+-\s+/)) {
          const text = line.replace(/^\s+-\s+/, '').trim();
          const parts = text.split('|');
          result.push({ name: parts[0].trim(), price: parts[1]?.trim() || '' });
        } else if (line.match(/^\w/)) { collecting = false; }
      }
    }
    return result;
  };

  for (const line of fmLines) {
    if (line.startsWith('date:')) { dm.date = line.replace('date:', '').trim().replace(/"/g, ''); break; }
  }
  dm.soups      = parseSection('soups');
  dm.bezlepkova = parseSection('bezlepkova');
  dm.bezmasa    = parseSection('bezmasa');
  dm.hotova     = parseSection('hotova');
  dm.gril       = parseSection('gril');
  dm.salaty     = parseSection('salaty');
  dm.dezerty    = parseSection('dezerty');
} catch(e){ console.error('daily-menu parse error:', e); }

const allDailyItems = [
  ...dm.soups.map(i=>({...i,cat:'Polévky'})),
  ...dm.bezlepkova.map(i=>({...i,cat:'Bezlepková'})),
  ...dm.bezmasa.map(i=>({...i,cat:'Bezmasá'})),
  ...dm.hotova.map(i=>({...i,cat:'Hotová jídla'})),
  ...dm.gril.map(i=>({...i,cat:'Gril & wok'})),
  ...dm.salaty.map(i=>({...i,cat:'Saláty'})),
  ...dm.dezerty.map(i=>({...i,cat:'Dezerty'})),
];
---

<BaseLayout title="Jídelní lístek" description="Jídelní a nápojový lístek Hostince Antonín Barták v Městečku. Denní menu, stálý jídelní lístek, nápojový lístek.">
  <Header />

  <div class="page-hero">
    <div class="container">
