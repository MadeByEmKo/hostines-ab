---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Objednat s sebou"
  description="Objednávky jídel s sebou z Hostince AB."
>
  <Header />

  <div class="page-hero">
    <div class="container">
      <span class="badge">Takeaway</span>
      <h1 class="mt-md page-title-with-icon">
        <i class="fa-solid fa-utensils title-icon-gold"></i>
        Objednat s sebou
      </h1>
    </div>
  </div>

  <div class="container" style="max-width: 800px; margin: 40px auto;">
    <section class="order-page">
      <!-- DENNÍ LÍSTEK - HNED NA ZAČÁTKU -->
      <div class="daily-menu-preview">
        <h2>Dnešní nabídka</h2>
        
        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>Italská tomatová polévka s pestem a tarhoňou</h3>
            <span class="price">59 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="01">Přidat</button>
        </div>
        
        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>Slepičí vývar s masem, zeleninkou a kapáním</h3>
            <span class="price">59 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="02">Přidat</button>
        </div>
        
        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>Dršťková jemně pikantní z hlívy ústřičné</h3>
            <span class="price">59 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="03">Přidat</button>
        </div>

        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>200g Asijský vepřový bůček se sezamem, jasmínová rýže</h3>
            <span class="price">209 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="04">Přidat</button>
        </div>

        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>120g Smažený sýr GOUDA, tatarská omáčka</h3>
            <span class="price">199 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="05">Přidat</button>
        </div>

        <div class="menu-item-card">
          <div class="menu-item-header">
            <h3>350g Italské krémové zeleninové rizoto se žampióny a parmezánem</h3>
            <span class="price">189 Kč</span>
          </div>
          <button class="btn-add-to-order" data-item="06">Přidat</button>
        </div>
      </div>

      <!-- OBJEDNÁVKOVÝ FORMULÁŘ -->
      <div class="order-form-container">
        <h2>Vaše objednávka</h2>
        
        <form id="order-form" class="order-form" action="https://formspree.io/f/ZZZZZZZZ" method="POST">
          <!-- SKRYTÉ POLE PRO OBSAH OBJEDNÁVKY -->
          <input type="hidden" name="obsah_objednavky" id="hidden-order-content">
          
          <!-- SHRNUTÍ OBJEDNÁVKY -->
          <div class="order-summary" id="order-summary">
            <div class="empty-state">Vyberte si položky z nabídky výše</div>
          </div>

          <!-- KONTAKTNÍ ÚDAJE -->
          <fieldset class="form-section">
            <legend>Vaše údaje</legend>
            <input type="text" name="name" placeholder="Jméno *" required>
            <input type="email" name="email" placeholder="Email *" required>
            <input type="tel" name="phone" placeholder="Telefon *" required>
          </fieldset>

          <!-- ZPŮSOB VYZVEDNUTÍ -->
          <fieldset class="form-section">
            <legend>Způsob vyzvednutí</legend>
            
            <label class="delivery-option">
              <input type="radio" name="delivery" value="pickup" checked>
              <div class="delivery-option-content">
                <strong>Vyzvednu osobně</strong>
                <small>Zdarma, 30-45 minut</small>
              </div>
            </label>
            
            <label class="delivery-option">
              <input type="radio" name="delivery" value="delivery">
              <div class="delivery-option-content">
                <strong>Doručení domů</strong>
                <small>+50 Kč, 45 minut</small>
              </div>
            </label>
          </fieldset>

          <!-- ČAS VYZVEDNUTÍ -->
          <fieldset class="form-section">
            <legend>Čas vyzvednutí</legend>
            
            <label class="time-option">
              <input type="radio" name="time" value="now" checked>
              <span>Nyní (do 30 minut)</span>
            </label>
            
            <label class="time-option">
              <input type="radio" name="time" value="30min">
              <span>Za 30 minut</span>
            </label>
            
            <label class="time-option">
              <input type="radio" name="time" value="1hour">
              <span>Za 1 hodinu</span>
            </label>
          </fieldset>

          <!-- POZNÁMKY -->
          <fieldset class="form-section">
            <legend>Poznámky k objednávce</legend>
            <textarea name="notes" placeholder="Bez cibule, bez soli, atd."></textarea>
          </fieldset>

          <!-- CENA -->
          <div class="order-total">
            <div class="total-row">
              <span>Jídlo:</span>
              <span id="food-price">0 Kč</span>
            </div>
            <div class="total-row" id="delivery-row" style="display:none;">
              <span>Doručení:</span>
              <span>+50 Kč</span>
            </div>
            <div class="total-row total">
              <span>CELKEM:</span>
              <span id="total-price">0 Kč</span>
            </div>
          </div>

          <!-- TLAČÍTKO -->
          <button type="submit" class="btn btn-primary btn-full">Odeslat objednávku</button>
        </form>
        
        <div class="form-success hidden" id="takeaway-success" style="display:none; text-align:center; padding:40px 0;">
          <div style="font-size:3rem; margin-bottom:1rem;">✅</div>
          <h3 style="color:var(--clr-gold);">Objednávka přijata!</h3>
          <p>Zavoláme Vám pro potvrzení.</p>
          <button class="btn btn-outline mt-lg" onclick="location.reload()">Objednat znovu</button>
        </div>
      </div>
    </section>
  </div>

  <Footer />
</BaseLayout>

<style>
/* DENNÍ LÍSTEK - PREVIEW */
.daily-menu-preview {
  margin-bottom: 40px;
  padding: 20px;
  background: rgba(212, 175, 55, 0.05);
  border-radius: 8px;
  border: 1px solid #D4AF37;
}

.daily-menu-preview h2 {
  color: #D4AF37;
  font-size: 20px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

/* MENU ITEM CARD */
.menu-item-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid #333;
  border-radius: 6px;
  padding: 12px;
  margin-bottom: 10px;
  transition: all 0.3s ease;
}

.menu-item-card:hover {
  background: rgba(212, 175, 55, 0.1);
  border-color: #D4AF37;
}

.menu-item-card h3 {
  font-size: 14px;
  margin: 0 0 8px 0;
  color: #fff;
  font-weight: 600;
  line-height: 1.4;
}

.menu-item-card .price {
  color: #D4AF37;
  font-size: 16px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}

.menu-item-card .menu-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 8px;
}

/* TLAČÍTKO PŘIDAT */
.btn-add-to-order {
  width: 100%;
  padding: 8px;
  background: #D4AF37;
  color: #1a3a2a;
  border: none;
  border-radius: 4px;
  font-weight: bold;
  cursor: pointer;
  font-size: 13px;
  transition: all 0.3s ease;
}

.btn-add-to-order:hover {
  background: #E8C547;
  transform: scale(1.02);
}

.btn-add-to-order:active {
  transform: scale(0.98);
}

/* OBJEDNÁVKOVÝ FORMULÁŘ */
.order-form-container {
  background: rgba(20, 50, 40, 0.5);
  padding: 20px;
  border-radius: 8px;
  border: 1px solid #D4AF37;
}

.order-form-container h2 {
  color: #D4AF37;
  font-size: 18px;
  margin-top: 0;
}

/* SHRNUTÍ OBJEDNÁVKY */
.order-summary {
  background: rgba(212, 175, 55, 0.05);
  padding: 15px;
  border-radius: 6px;
  margin-bottom: 20px;
  max-height: 300px;
  overflow-y: auto;
}

.order-summary .empty-state {
  text-align: center;
  color: #999;
  font-size: 13px;
  padding: 20px;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #333;
  font-size: 13px;
}

.order-item:last-child {
  border-bottom: none;
}

.order-item-name {
  flex: 1;
  margin-right: 10px;
  color: #fff;
}

.order-item-price {
  color: #D4AF37;
  font-weight: bold;
  white-space: nowrap;
}

.order-item-remove {
  margin-left: 10px;
  cursor: pointer;
  color: #999;
  font-size: 16px;
}

/* FORMULÁŘ */
.form-section {
  border: none;
  margin-bottom: 15px;
  padding: 0;
}

.form-section legend {
  display: block;
  font-weight: bold;
  margin-bottom: 10px;
  color: #D4AF37;
  font-size: 13px;
}

.form-section input[type="text"],
.form-section input[type="email"],
.form-section input[type="tel"],
.form-section textarea {
  width: 100%;
  padding: 10px;
  margin-bottom: 8px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid #444;
  border-radius: 4px;
  color: #fff;
  font-size: 14px;
  box-sizing: border-box;
}

.form-section textarea {
  resize: vertical;
  min-height: 80px;
}

/* DELIVERY OPTIONS */
.delivery-option {
  display: flex;
  padding: 10px;
  margin-bottom: 8px;
  background: rgba(255, 255, 255, 0.05);
  border: 2px solid #D4AF37;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.delivery-option input[type="radio"] {
  margin-right: 10px;
  cursor: pointer;
}

.delivery-option input[type="radio"]:checked + .delivery-option-content {
  color: #D4AF37;
}

.delivery-option-content strong {
  display: block;
  margin-bottom: 2px;
  color: #fff;
}

.delivery-option input[type="radio"]:checked + .delivery-option-content strong {
  color: #D4AF37;
}

.delivery-option-content small {
  display: block;
  font-size: 12px;
  opacity: 0.8;
  color: #ccc;
}

/* TIME OPTIONS */
.time-option {
  display: flex;
  margin-bottom: 8px;
  cursor: pointer;
}

.time-option input[type="radio"] {
  margin-right: 8px;
  cursor: pointer;
}

.time-option span {
  color: #fff;
}

/* CENA */
.order-total {
  background: rgba(212, 175, 55, 0.1);
  padding: 15px;
  border-radius: 6px;
  margin: 20px 0;
  border: 1px solid #D4AF37;
}

.total-row {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  margin-bottom: 8px;
  padding-bottom: 8px;
  border-bottom: 1px solid #333;
  color: #fff;
}

.total-row.total {
  font-size: 16px;
  font-weight: bold;
  color: #D4AF37;
  border: none;
  margin-bottom: 0;
}

/* BUTTON */
.btn-full {
  width: 100%;
  padding: 12px;
  font-size: 16px;
  font-weight: bold;
}

/* MOBILE OPTIMIZACE */
@media (max-width: 768px) {
  .daily-menu-preview {
    padding: 15px;
    margin-bottom: 30px;
  }

  .menu-item-card {
    padding: 10px;
    margin-bottom: 8px;
  }

  .menu-item-card h3 {
    font-size: 13px;
  }

  .order-form-container {
    padding: 15px;
  }

  .form-section input,
  .form-section textarea {
    padding: 8px;
    font-size: 13px;
  }
}
</style>

<script>
// Globální variable pro objednávku
let orderItems = {};
let orderPrices = {
  '01': 59, '02': 59, '03': 59, '04': 209, '05': 199, '06': 189
};

// Vystavení funkce do window, abychom ji mohli volat z HTML onclick
window.removeItem = function(itemId) {
  if (orderItems[itemId]) {
    orderItems[itemId].quantity--;
    if (orderItems[itemId].quantity <= 0) {
      delete orderItems[itemId];
    }
    updateOrderSummary();
    updateTotal();
  }
};

// Přidání položky do objednávky
document.querySelectorAll('.btn-add-to-order').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const target = e.target as HTMLElement;
    const itemId = target.dataset.item;
    if(!itemId) return;
    const itemName = target.parentElement?.querySelector('h3')?.textContent || 'Položka';
    const itemPrice = orderPrices[itemId as keyof typeof orderPrices];
    
    if (!orderItems[itemId]) {
      orderItems[itemId] = {
        id: itemId,
        name: itemName,
        price: itemPrice,
        quantity: 0
      };
    }
    
    orderItems[itemId].quantity++;
    updateOrderSummary();
    updateTotal();
    
    // Změna textu tlačítka pro zpětnou vazbu
    const originalText = target.textContent;
    target.textContent = '✓ Přidáno';
    setTimeout(() => { target.textContent = originalText; }, 1000);
  });
});

// Update shrnutí objednávky
function updateOrderSummary() {
  const summary = document.getElementById('order-summary');
  if(!summary) return;
  const items = Object.values(orderItems).filter((item: any) => item.quantity > 0) as any[];
  
  if (items.length === 0) {
    summary.innerHTML = '<div class="empty-state">Vyberte si položky z nabídky výše</div>';
    (document.getElementById('hidden-order-content') as HTMLInputElement).value = '';
    return;
  }
  
  let html = '';
  let hiddenContent = 'Objednávka:\n';
  
  items.forEach(item => {
    const subtotal = item.price * item.quantity;
    html += `
      <div class="order-item">
        <div class="order-item-name">
          ${item.name} <strong>x${item.quantity}</strong>
        </div>
        <div class="order-item-price">${subtotal} Kč</div>
        <span class="order-item-remove" onclick="window.removeItem('${item.id}')" title="Odebrat">✕</span>
      </div>
    `;
    hiddenContent += `- ${item.name} (x${item.quantity}): ${subtotal} Kč\n`;
  });
  
  summary.innerHTML = html;
  (document.getElementById('hidden-order-content') as HTMLInputElement).value = hiddenContent;
}

// Výpočet ceny
function updateTotal() {
  let foodPrice = 0;
  Object.values(orderItems).forEach((item: any) => {
    foodPrice += item.price * item.quantity;
  });
  
  const deliveryInput = document.querySelector('input[name="delivery"]:checked') as HTMLInputElement;
  const delivery = deliveryInput ? deliveryInput.value : 'pickup';
  const deliveryFee = delivery === 'delivery' ? 50 : 0;
  const total = foodPrice + deliveryFee;
  
  const foodPriceEl = document.getElementById('food-price');
  const totalPriceEl = document.getElementById('total-price');
  if(foodPriceEl) foodPriceEl.textContent = foodPrice + ' Kč';
  if(totalPriceEl) totalPriceEl.textContent = total + ' Kč';
  
  const deliveryRow = document.getElementById('delivery-row');
  if(deliveryRow) {
    if (delivery === 'delivery') {
      deliveryRow.style.display = 'flex';
    } else {
      deliveryRow.style.display = 'none';
    }
  }
}

// Change delivery method
document.querySelectorAll('input[name="delivery"]').forEach(radio => {
  radio.addEventListener('change', updateTotal);
});

// Form submit
const orderForm = document.getElementById('order-form');
if(orderForm) {
  orderForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    const items = Object.values(orderItems);
    if(items.length === 0) {
      alert("Nejprve přidejte položky do objednávky.");
      return;
    }
    
    // Odeslání formuláře přes fetch (Formspree nebo vlastní endpoint)
    const form = e.target as HTMLFormElement;
    try {
      const res = await fetch(form.action, {
        method: 'POST', 
        body: new FormData(form), 
        headers: { Accept: 'application/json' }
      });
      if (res.ok) {
        form.style.display = 'none';
        const successEl = document.getElementById('takeaway-success');
        if(successEl) successEl.style.display = 'block';
      } else {
        alert("Chyba při odesílání objednávky. Zkuste to prosím znovu.");
      }
    } catch (err) { 
      // Fallback
      form.submit(); 
    }
  });
}

// Inicializace
updateOrderSummary();
updateTotal();
</script>
