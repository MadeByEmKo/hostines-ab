---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getUrl } from '../utils/paths.js';
import { readFileSync } from 'fs';
import { join } from 'path';

let dm = { date:'', soups:[], bezlepkova:[], bezmasa:[], hotova:[], gril:[], salaty:[], dezerty:[] };
try {
  const raw = readFileSync(join(process.cwd(),'content/daily-menu.md'),'utf8');
  const fm = raw.match(/^---\n([\s\S]*?)\n---/);
  const parseSection = (key) => {
    const m = raw.match(new RegExp(key+':\n([\\s\\S]*?)(?=\\w+:|---)'));
    return m ? m[1].split('\n').filter(l=>l.trim().startsWith('-')).map(l=>{
      const [name,price]=l.replace(/^\s*-\s*/,'').split('|').map(s=>s.trim());
      return {name,price:price||''};
    }) : [];
  };
  if(fm) fm[1].split('\n').forEach(l=>{if(l.startsWith('date:'))dm.date=l.replace('date:','').trim().replace(/"/g,'');});
  dm.soups=parseSection('soups'); dm.bezlepkova=parseSection('bezlepkova');
  dm.bezmasa=parseSection('bezmasa'); dm.hotova=parseSection('hotova');
  dm.gril=parseSection('gril'); dm.salaty=parseSection('salaty');
  dm.dezerty=parseSection('dezerty');
} catch(e){}

const allDailyItems = [
  ...dm.soups.map(i=>({...i,cat:'Polévky'})),
  ...dm.bezlepkova.map(i=>({...i,cat:'Bezlepková'})),
  ...dm.bezmasa.map(i=>({...i,cat:'Bezmasá'})),
  ...dm.hotova.map(i=>({...i,cat:'Hotová jídla'})),
  ...dm.gril.map(i=>({...i,cat:'Gril & wok'})),
  ...dm.salaty.map(i=>({...i,cat:'Saláty'})),
  ...dm.dezerty.map(i=>({...i,cat:'Dezerty'})),
];
---

<BaseLayout title="Jídelní lístek" description="Jídelní a nápojový lístek Hostince Antonín Barták v Městečku. Denní menu, stálý jídelní lístek, nápojový lístek.">
  <Header />

  <div class="page-hero">
    <div class="container">
      <span class="badge">Kuchyně</span>
      <h1 class="mt-md">Jídelní & nápojový lístek</h1>
      <p class="lead mt-md">Poctivá česká kuchyně · Denní menu 11–14 hod · Rozvoz od 4 jídel do 10 km zdarma</p>
    </div>
  </div>

  <section class="section" id="denni">
    <div class="container">
      <div class="menu-tabs reveal">
        <button class="tab-btn active" id="tab-denni"   data-tab="denni">
          <i class="fa-solid fa-calendar-days"></i>
          <span class="tab-label-desktop">Denní menu</span>
          <span class="tab-label-mobile">Denní</span>
        </button>
        <button class="tab-btn"        id="tab-jidelni" data-tab="jidelni">
          <i class="fa-solid fa-utensils"></i>
          <span class="tab-label-desktop">Jídelní lístek</span>
          <span class="tab-label-mobile">Jídelní</span>
        </button>
        <button class="tab-btn"        id="tab-napoje"  data-tab="napoje">
          <i class="fa-solid fa-wine-bottle"></i>
          <span class="tab-label-desktop">Nápojový lístek</span>
          <span class="tab-label-mobile">Nápoje</span>
        </button>
      </div>

      <!-- DENNÍ MENU -->
      <div class="tab-content" id="content-denni">
        <div class="daily-header">
          <div>
            <h2>Denní menu</h2>
            <p class="lead">Platné {dm.date || 'dnes'} · Vydáváme 11:00 – 14:00</p>
          </div>
          <div class="daily-badge-wrap">
            <span class="daily-price-badge">od 59 Kč</span>
            <a href={getUrl('/objednat')} class="btn btn-primary btn-sm no-print" id="menu-order-btn"><i class="fa-solid fa-bag-shopping icon-white"></i> Objednat s sebou</a>
            <button class="btn btn-ghost btn-sm no-print" id="menu-print-btn" onclick="window.print()"><i class="fa-solid fa-print"></i> Tisk</button>
          </div>
        </div>

        {allDailyItems.length > 0 ? (
          <div class="menu-card">
            {[
              {key:'soups',    emoji:'fa-solid fa-bowl-food', title:'Polévky',        items:dm.soups},
              {key:'bezlepkova',emoji:'fa-solid fa-wheat-awn', title:'Bezlepková jídla',items:dm.bezlepkova},
              {key:'bezmasa',  emoji:'fa-solid fa-seedling',   title:'Bezmasá jídla',  items:dm.bezmasa},
              {key:'hotova',   emoji:'fa-solid fa-utensils',   title:'Hotová jídla',   items:dm.hotova},
              {key:'gril',     emoji:'fa-solid fa-fire',       title:'Jídla z grilu a wok', items:dm.gril},
              {key:'salaty',   emoji:'fa-solid fa-carrot',     title:'Saláty',         items:dm.salaty},
              {key:'dezerty',  emoji:'fa-solid fa-cake-candles', title:'Dezerty',        items:dm.dezerty},
            ].filter(s=>s.items.length>0).map(sec=>(
              <div class="menu-category">
                <div class="menu-category-title"><i class={sec.emoji}></i> {sec.title}</div>
                {sec.items.map(item=>(
                  <div class="menu-item menu-item-clickable"
                    data-name={item.name} data-price={item.price}
                    role="button" tabindex="0" title="Klikněte pro objednávku s sebou">
                    <div>
                      <div class="menu-item-name">{item.name}</div>
                    </div>
                    <div class="menu-item-right">
                      <div class="menu-item-price">{item.price}</div>
                      <a href={getUrl(`/objednat?item=${encodeURIComponent(item.name)}&price=${encodeURIComponent(item.price)}`)}
                         class="order-badge" title="Objednat s sebou"><i class="fa-solid fa-bag-shopping"></i></a>
                    </div>
                  </div>
                ))}
              </div>
            ))}
            <div class="menu-note">
              <i class="fa-solid fa-phone"></i> Objednávky: <strong>737 484 116</strong> · Rozvoz od 4 jídel do 10 km zdarma
            </div>
          </div>
        ) : (
          <div class="daily-placeholder">
            <div class="placeholder-icon"><i class="fa-solid fa-utensils"></i></div>
            <h3>Dnešní menu bude brzy zveřejněno</h3>
            <p>Aktuální nabídku zjistíte telefonicky nebo na Facebooku.</p>
            <div class="flex gap-md flex-wrap items-center mt-lg" style="justify-content:center">
              <a href="tel:+420737484116" class="btn btn-primary" id="menu-phone-btn">+420 737 484 116</a>
            </div>
          </div>
        )}
      </div>

      <!-- JÍDELNÍ LÍSTEK -->
      <div class="tab-content hidden" id="content-jidelni">
        <div class="menu-print-bar no-print">
          <p class="lead">Stálý jídelní lístek · Ceny včetně DPH</p>
          <button class="btn btn-ghost btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Vytisknout</button>
        </div>
        <div class="menu-image-container reveal">
          <picture>
            <source srcset={`${getUrl('/images/menu-mobile.webp')} 480w`} type="image/webp" media="(max-width: 480px)" />
            <source srcset={`${getUrl('/images/menu-tablet.webp')} 768w`} type="image/webp" media="(max-width: 768px)" />
            <source srcset={`${getUrl('/images/menu.webp')}`} type="image/webp" />
            <img src={getUrl('/images/menu.png')} alt="Jídelní lístek" class="shimmer-img menu-sheet" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
        </div>
      </div>

      <!-- NÁPOJOVÝ LÍSTEK -->
      <div class="tab-content hidden" id="content-napoje">
        <div class="menu-print-bar no-print">
          <p class="lead">Nápojový lístek · Ceny včetně DPH</p>
          <button class="btn btn-ghost btn-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> Vytisknout</button>
        </div>
        <div class="menu-image-container reveal">
          <picture>
            <source srcset={`${getUrl('/images/drinks-mobile.webp')} 480w`} type="image/webp" media="(max-width: 480px)" />
            <source srcset={`${getUrl('/images/drinks-tablet.webp')} 768w`} type="image/webp" media="(max-width: 768px)" />
            <source srcset={`${getUrl('/images/drinks.webp')}`} type="image/webp" />
            <img src={getUrl('/images/drinks.png')} alt="Nápojový lístek" class="shimmer-img menu-sheet" loading="lazy" onload="this.classList.add('loaded')" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .menu-tabs { display:flex; gap:var(--space-sm); border-bottom:2px solid var(--clr-border); margin-bottom:var(--space-2xl); flex-wrap:wrap; }
  .tab-btn { padding:.75rem 1.5rem; background:none; border:none; color:var(--clr-text-muted); font-family:var(--font-body); font-size:.9rem; font-weight:600; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-2px; transition:color .2s,border-color .2s; display:inline-flex; align-items:center; gap:0.5rem; }
  .tab-btn:hover { color:var(--clr-cream); }
  .tab-btn.active { color:var(--clr-gold); border-bottom-color:var(--clr-gold); }
  .hidden { display:none!important; }
  .tab-label-mobile { display:none; }
  .daily-header { display:flex; justify-content:space-between; align-items:flex-start; gap:var(--space-lg); margin-bottom:var(--space-xl); flex-wrap:wrap; }
  .daily-badge-wrap { display:flex; align-items:center; gap:var(--space-sm); flex-wrap:wrap; }
  .daily-price-badge { background:linear-gradient(135deg,var(--clr-gold),var(--clr-gold-dark)); color:var(--clr-bg); font-weight:700; font-size:1.05rem; padding:.4rem 1rem; border-radius:var(--radius-sm); font-family:var(--font-display); }
  .menu-card { background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-lg); padding:var(--space-2xl); }
  .menu-item-clickable { cursor:pointer; border-radius:var(--radius-sm); transition:background .15s; }
  .menu-item-clickable:hover { background:rgba(201,168,76,.06); }
  .menu-item-right { display:flex; align-items:center; gap:var(--space-sm); flex-shrink:0; }
  .order-badge { font-size:1rem; opacity:.5; transition:opacity .2s; text-decoration:none; }
  .menu-item-clickable:hover .order-badge { opacity:1; }
  .menu-note { margin-top:var(--space-xl); padding-top:var(--space-lg); border-top:1px solid var(--clr-border); font-size:.85rem; color:var(--clr-text-muted); text-align:center; line-height:1.8; }
  .menu-print-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-xl); flex-wrap:wrap; gap:var(--space-md); }
  .daily-placeholder { text-align:center; padding:var(--space-3xl); background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-lg); }
  .placeholder-icon { font-size:3rem; margin-bottom:var(--space-lg); }
  
  .menu-image-container {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
  }
  .menu-sheet {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width:600px) {
    .menu-card { padding:var(--space-lg); }
    .daily-header { flex-direction:column; }
    .tab-label-desktop { display:none; }
    .tab-label-mobile { display:inline; }
    .menu-image-container { border-radius: var(--radius-md); }
    .menu-tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
      scrollbar-width: none;
    }
    .menu-tabs::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex: 1;
      text-align: center;
      white-space: nowrap;
      padding: 0.75rem 1rem;
      justify-content: center;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.add('hidden'));
      tab.classList.add('active');
      document.getElementById(`content-${tab.getAttribute('data-tab')}`)?.classList.remove('hidden');
    });
  });
  if (window.location.hash === '#napoje') document.getElementById('tab-napoje')?.click();
</script>
