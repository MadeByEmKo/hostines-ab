          <span class="tab-label-mobile">Denní</span>
        </button>
        <button class="tab-btn"        id="tab-jidelni" data-tab="jidelni">
          <i class="fa-solid fa-utensils"></i>
          <span class="tab-label-desktop">Jídelní lístek</span>
          <span class="tab-label-mobile">Stálice</span>
        </button>
        <button class="tab-btn"        id="tab-napoje"  data-tab="napoje">
          <i class="fa-solid fa-wine-bottle"></i>
          <span class="tab-label-desktop">Nápojový lístek</span>
          <span class="tab-label-mobile">Nápoje</span>
        </button>
      </div>

      <!-- DENNÍ MENU -->
      <div class="tab-content" id="content-denni">
        <div class="daily-header">
          <div>
            <h2>Denní menu</h2>
            <p class="lead">Platné {dm.date || 'dnes'} · Vydáváme 11:00 – 14:00</p>
          </div>
          <div class="daily-badge-wrap">
            <span class="daily-price-badge">od 59 Kč</span>
            <a href={getUrl('/objednat')} class="btn btn-primary btn-sm no-print" id="menu-order-btn"><i class="fa-solid fa-bag-shopping icon-white"></i> Objednat s sebou</a>
            <button class="btn btn-ghost btn-sm no-print" id="menu-print-btn" onclick="window.print()"><i class="fa-solid fa-print"></i> Tisk</button>
          </div>
        </div>

        {allDailyItems.length > 0 ? (
          <div class="menu-card">
            {[
              {key:'soups',    emoji:'fa-solid fa-bowl-food', title:'Polévky',        items:dm.soups},
              {key:'bezlepkova',emoji:'fa-solid fa-wheat-awn', title:'Bezlepková jídla',items:dm.bezlepkova},
              {key:'bezmasa',  emoji:'fa-solid fa-seedling',   title:'Bezmasá jídla',  items:dm.bezmasa},
              {key:'hotova',   emoji:'fa-solid fa-utensils',   title:'Hotová jídla',   items:dm.hotova},
              {key:'gril',     emoji:'fa-solid fa-fire',       title:'Jídla z grilu a wok', items:dm.gril},
              {key:'salaty',   emoji:'fa-solid fa-carrot',     title:'Saláty',         items:dm.salaty},
              {key:'dezerty',  emoji:'fa-solid fa-cake-candles', title:'Dezerty',        items:dm.dezerty},
            ].filter(s=>s.items.length>0).map(sec=>(
              <div class="menu-category">
                <div class="menu-category-title"><i class={sec.emoji}></i> {sec.title}</div>
                {sec.items.map(item=>(
                  <div class="menu-item menu-item-clickable"
                    data-name={item.name} data-price={item.price}
                    role="button" tabindex="0" title="Klikněte pro objednávku s sebou">
                    <div>
                      <div class="menu-item-name">{item.name}</div>
                    </div>
                    <div class="menu-item-right">
                      <div class="menu-item-price">{item.price}</div>
                      <a href={getUrl(`/objednat?item=${encodeURIComponent(item.name)}&price=${encodeURIComponent(item.price)}`)}
                         class="order-badge" title="Objednat s sebou"><i class="fa-solid fa-bag-shopping"></i></a>
                    </div>
                  </div>
                ))}
              </div>
            ))}
            <div class="menu-note">
              <i class="fa-solid fa-phone"></i> Objednávky: <strong>737 484 116</strong> · Rozvoz od 4 jídel do 10 km zdarma
            </div>
          </div>
        ) : (
          <div class="daily-placeholder">
            <div class="placeholder-icon"><i class="fa-solid fa-utensils"></i></div>
            <h3>Dnešní menu bude brzy zveřejněno</h3>
            <p>Aktuální nabídku zjistíte telefonicky nebo na Facebooku.</p>
